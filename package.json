{
  "name": "ciac-registro",
  "version": "1.0.0",
  "description": "Aplicación de registro de participación CIAC usando Electron y SQLite",
  "author": "Andres Miranda Villavicencio",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable zip"
  },
{
  "dependencies": {
    "better-sqlite3": "^9.4.0",
    "xlsx": "^0.18.5"
  }
}
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "cl.usm.ciac.registro",
    "productName": "CIAC Registro",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "zip"
      ]
    }
  }
}
